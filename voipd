# the Free Software Foundation; either version 2 of the License, or
# (at your option) any later version.
#
# Four routing modes available — see ROUTING_MODE below:
#
#   b2bua_netns  (default, recommended)
#                     Sandboxed Back-to-Back User Agent.  The B2BUA process
#                     runs inside a Linux network namespace connected to the
#                     router via a veth pair.  All SIP traffic passes through
#                     router via a veth pair.  Upstream SIP/RTP is forwarded
#                     traffic (not router-originated), so it passes through the
#                     FORWARD chain where UniFi applies ALIEN/TOR threat
#                     intelligence blocking and IPS unconditionally.  Note: the
#                     voip interface is not auto-zoned by UniFi (only UI-managed
#                     interfaces are), so zone-specific rules do not apply here,
#                     but ALIEN and IPS are zone-independent FORWARD-chain rules.
#                     Requires VOIP_B2BUA_USER / PASS / DOMAIN and
#                     PCSCF_HOSTNAME to be set.
#
#   b2bua        (deprecated)
#                     Signaling-only Back-to-Back User Agent (non-sandboxed).
#                     The B2BUA process runs directly on the router; SIP traffic
#                     upstream SIP/RTP is router-originated (OUTPUT chain) so
#                     it does not pass through FORWARD-chain rules such as
#                     ALIEN/TOR blocking or IPS.  Use b2bua_netns instead.
#                     PCSCF_HOSTNAME is not required.  Kept for compatibility —
#                     use b2bua_netns for new deployments.
#
#   pbr               Policy-Based Routing.
#                     Creates a dedicated routing table and ip rules so IMS
#                     traffic always exits via the voip interface, regardless
#                     of UniFiOS default WAN priority.
#
#   forward           Forward VoIP traffic through a specific existing
#                     interface/VLAN instead of the voip interface itself.
#                     Use this if you want to steer traffic through a
#                     different physical port or pre-existing VLAN.

# ============================================================
#  DEFAULTS — overridden by /data/voip/voipd.conf
#  Do NOT edit here. Edit /data/voip/voipd.conf instead,
#  or use the web UI at https://<gateway>/voip
# ============================================================

VOIP_WAN_INTERFACE="eth4"
VOIP_WAN_VLAN="11"
VOIP_WAN_VLAN_INTERFACE="voip"
VOIP_WAN_VLAN_INTERFACE_EGRESS_QOS="0:5 1:5 2:5 3:5 4:5 5:5 6:5 7:5"
PCSCF_HOSTNAME="p-cscf.example.com"
ROUTING_MODE="b2bua_netns"
VOIP_RT_TABLE="203"
VOIP_RT_TABLE_NAME="voip"
VOIP_FORWARD_INTERFACE=""
VOIP_FORWARD_GATEWAY=""
VOIP_IMS_SUBNET=""
VOIP_VPN_INTERFACES=""
UBIOS_NAT_CHAIN="UBIOS_POSTROUTING_USER_HOOK"
VOIP_STATE_DIR="/var/run/voipd"
VOIP_DEBUG="false"
# B2BUA mode settings (only used when ROUTING_MODE=b2bua)
VOIP_B2BUA_USER=""
VOIP_B2BUA_PASS=""
VOIP_B2BUA_DOMAIN=""
VOIP_B2BUA_LISTEN_PORT="5060"
VOIP_B2BUA_LOCAL_USER=""
VOIP_B2BUA_LOCAL_PASS=""
VOIP_B2BUA_REG_EXPIRES="600"

# Source user configuration — overrides defaults above
[ -f /data/voip/voipd.conf ] && . /data/voip/voipd.conf

# ============================================================
#  INTERNALS — do not edit below this line
# ============================================================

_debug() { [ "$VOIP_DEBUG" = "true" ] && echo "[DEBUG] $*" >&2; }

# ── DHCP ──────────────────────────────────────────────────────────────────────

_dhcp_start() {
    echo "Starting DHCP on $VOIP_WAN_VLAN_INTERFACE via systemd-networkd"
    mkdir -p "$VOIP_STATE_DIR"

    cat > /etc/systemd/network/99-voip.network << NETEOF
[Match]
Name=$VOIP_WAN_VLAN_INTERFACE

[Network]
DHCP=ipv4
LLMNR=no
MulticastDNS=no

[DHCP]
UseDNS=true
UseRoutes=false
SendHostname=false
NETEOF

    systemctl restart systemd-networkd

    echo "Waiting for DHCP lease..."
    local waited=0
    while [ $waited -lt 30 ]; do
        ip addr show "$VOIP_WAN_VLAN_INTERFACE" 2>/dev/null | grep -q "inet " && break
        sleep 1; waited=$((waited + 1))
    done

    if ip addr show "$VOIP_WAN_VLAN_INTERFACE" 2>/dev/null | grep -q "inet "; then
        local got
        got=$(ip addr show "$VOIP_WAN_VLAN_INTERFACE" | awk '/inet /{print $2}')
        echo "DHCP OK: $got"
    else
        echo "ERROR: DHCP did not complete within 30s"
        return 1
    fi
}

_dhcp_stop() {
    rm -f /etc/systemd/network/99-voip.network
    systemctl restart systemd-networkd
}

# ── P-CSCF DNS lookup helper ──────────────────────────────────────────────────
# Resolves PCSCF_HOSTNAME using the DNS server from the VoIP DHCP lease.
# Prints the resolved IP to stdout, or nothing on failure. No side effects,
# no sleep — safe to call before routing rules are installed (the VoIP
# interface is already up after _dhcp_start so its subnet route exists).

_resolve_pcscf_ip() {
    [ -z "$PCSCF_HOSTNAME" ] && return 0
    local pcscf_ip dns_server iface_index
    iface_index=$(ip link show "$VOIP_WAN_VLAN_INTERFACE" 2>/dev/null \
        | awk -F': ' 'NR==1{print $1}')

    # 1. DNS from systemd-networkd lease file for this interface
    if [ -n "$iface_index" ] && [ -f "/run/systemd/netif/leases/$iface_index" ]; then
        dns_server=$(grep "^DNS=" "/run/systemd/netif/leases/$iface_index" \
            2>/dev/null | cut -d'=' -f2 | awk '{print $1}')
    fi
    # 2. Fallback: find lease by assigned IP address
    if [ -z "$dns_server" ] && [ -n "$VOIP_IP" ]; then
        local lf
        lf=$(grep -rl "ADDRESS=$VOIP_IP" /run/systemd/netif/leases/ 2>/dev/null | head -1)
        [ -n "$lf" ] && \
            dns_server=$(grep "^DNS=" "$lf" 2>/dev/null | cut -d'=' -f2 | awk '{print $1}')
    fi
    # 3. Fallback: resolvectl
    [ -z "$dns_server" ] && \
        dns_server=$(resolvectl dns "$VOIP_WAN_VLAN_INTERFACE" 2>/dev/null \
            | sed 's/.*: //' | tr ' ' '\n' \
            | grep -E '^[0-9]{1,3}\.' | head -1)

    _debug "DNS for P-CSCF lookup: ${dns_server:-(not found)}"

    # Use short timeouts — this may be called before PBR routing is active.
    # If the ISP DNS server is only reachable via the voip table (not yet set up),
    # the query will fail fast here and succeed later in _resolve_pcscf.
    [ -n "$dns_server" ] && command -v nslookup >/dev/null 2>&1 && \
        pcscf_ip=$(nslookup "$PCSCF_HOSTNAME" "$dns_server" 2>/dev/null \
            | awk '/^Address:/{print $2}' | grep -Ev '#' \
            | grep -E '^[0-9]+\.[0-9]+\.[0-9]+\.[0-9]+$' | head -1)

    [ -z "$pcscf_ip" ] && [ -n "$dns_server" ] && command -v dig >/dev/null 2>&1 && \
        pcscf_ip=$(dig @"$dns_server" +short +time=2 +tries=1 "$PCSCF_HOSTNAME" \
            2>/dev/null | grep -E '^[0-9]+\.[0-9]+\.[0-9]+\.[0-9]+$' | head -1)

    [ -z "$pcscf_ip" ] && command -v getent >/dev/null 2>&1 && \
        pcscf_ip=$(getent hosts "$PCSCF_HOSTNAME" 2>/dev/null \
            | awk '{print $1}' | head -1)

    echo "$pcscf_ip"
}

# ── Subnet / IP detection ─────────────────────────────────────────────────────
# Reads the IP assigned to the VoIP VLAN interface, then resolves the P-CSCF
# proxy address (using the VoIP interface DNS) and derives the IMS subnet from
# the P-CSCF IP. This is more accurate than using the VoIP IP: the P-CSCF is
# the actual IMS entry point, so its subnet is the subnet we need to route.
# Falls back to the VoIP IP octet method if P-CSCF cannot be resolved.
# Can be fully overridden via VOIP_IMS_SUBNET in voipd.conf.

_subnet_from_ip() {
    # Print the summary RFC-1918 / CGNAT / private supernet for a given IP.
    local ip="$1" o1
    o1=$(echo "$ip" | cut -d'.' -f1)
    case "$o1" in
        10)  echo "10.0.0.0/8"      ;;
        100) echo "100.64.0.0/10"   ;;
        172) echo "172.16.0.0/12"   ;;
        192) echo "192.168.0.0/16"  ;;
        *)   echo "10.0.0.0/8"      ;;  # safe default
    esac
}

_detect_voip_config() {
    local voip_cidr voip_ip

    voip_cidr=$(ip addr show "$VOIP_WAN_VLAN_INTERFACE" 2>/dev/null \
        | grep "inet " | awk '{print $2}' | head -1)
    voip_ip=$(echo "$voip_cidr" | cut -d'/' -f1)

    if [ -z "$voip_ip" ]; then
        echo "ERROR: no IP on $VOIP_WAN_VLAN_INTERFACE"
        return 1
    fi

    VOIP_IP="$voip_ip"
    VOIP_CIDR="$voip_cidr"
    echo "  VoIP IP    : $voip_ip"

    if [ -n "$VOIP_IMS_SUBNET" ]; then
        VOIP_DEST_SUBNET="$VOIP_IMS_SUBNET"
        echo "  IMS subnet : $VOIP_DEST_SUBNET (manual override)"
    elif [ -s "$VOIP_STATE_DIR/subnet" ]; then
        # Use the subnet resolved during initial startup — avoids re-doing DNS
        # on watchdog restores when the IMS DNS server may be temporarily
        # unreachable (it lives in the IMS subnet we are trying to restore).
        VOIP_DEST_SUBNET=$(cat "$VOIP_STATE_DIR/subnet")
        echo "  IMS subnet : $VOIP_DEST_SUBNET (cached)"
    elif [ -z "$PCSCF_HOSTNAME" ]; then
        echo "ERROR: PCSCF_HOSTNAME is not set and VOIP_IMS_SUBNET is not set."
        echo "       Set PCSCF_HOSTNAME so the IMS subnet can be derived from the"
        echo "       P-CSCF address, or set VOIP_IMS_SUBNET to override manually."
        return 1
    else
        # The P-CSCF (IMS SIP proxy) is the authoritative source for the IMS subnet.
        # Its IP directly tells us which RFC-1918 block all IMS traffic lives on.
        #
        # Problem: the ISP DNS server is on the VoIP subnet and is only reachable
        # after routing voip routing table is installed — but we need the subnet to install
        # routing voip routing table.  To break this chicken-and-egg dependency we add a
        # temporary default route via the VoIP gateway just long enough to perform
        # the DNS lookup, then remove it.  The proper PBR/B2BUA rules are installed
        # immediately after this function returns.
        local _tmp_gw
        _tmp_gw=$(_get_gateway_for_iface "$VOIP_WAN_VLAN_INTERFACE")
        if [ -n "$_tmp_gw" ]; then
            ip route add default via "$_tmp_gw" dev "$VOIP_WAN_VLAN_INTERFACE" \
                metric 50 2>/dev/null || true
            _debug "Temporary default route via $_tmp_gw for P-CSCF DNS lookup"
        fi

        echo "  Resolving  : $PCSCF_HOSTNAME (for IMS subnet detection)..."
        local pcscf_ip
        pcscf_ip=$(_resolve_pcscf_ip)

        # Remove the temporary route immediately regardless of lookup outcome
        [ -n "$_tmp_gw" ] && \
            ip route del default via "$_tmp_gw" dev "$VOIP_WAN_VLAN_INTERFACE" \
                metric 50 2>/dev/null || true

        if [ -n "$pcscf_ip" ]; then
            echo "  P-CSCF     : $pcscf_ip"
            echo "$pcscf_ip" > "$VOIP_STATE_DIR/pcscf_ip"
            VOIP_DEST_SUBNET=$(_subnet_from_ip "$pcscf_ip")
            echo "  IMS subnet : $VOIP_DEST_SUBNET (auto from P-CSCF $pcscf_ip)"
        else
            echo "ERROR: could not resolve $PCSCF_HOSTNAME."
            echo "       Check that PCSCF_HOSTNAME is correct, or set VOIP_IMS_SUBNET"
            echo "       in voipd.conf to specify the IMS subnet manually."
            return 1
        fi
    fi

    echo "$VOIP_DEST_SUBNET" > "$VOIP_STATE_DIR/subnet"
    echo "$voip_ip"          > "$VOIP_STATE_DIR/voip_ip"
}

# ── Gateway detection ─────────────────────────────────────────────────────────
# Tries multiple sources in order: systemd-networkd lease files, networkctl,
# ip route, and finally a pure-shell network calculation as last resort.

_calc_network_gateway() {
    local ip="$1" prefix="$2"
    local o1 o2 o3 o4 mask ip_int net_int gw_int n1 n2 n3 n4

    o1=$(echo "$ip" | cut -d'.' -f1); o2=$(echo "$ip" | cut -d'.' -f2)
    o3=$(echo "$ip" | cut -d'.' -f3); o4=$(echo "$ip" | cut -d'.' -f4)

    if [ "$prefix" -ge 32 ]; then mask=4294967295
    elif [ "$prefix" -le 0 ]; then mask=0
    else
        local shift=$((32 - prefix)) divisor=1 i=0
        while [ $i -lt $shift ]; do divisor=$((divisor * 2)); i=$((i + 1)); done
        mask=$(( (4294967295 / divisor) * divisor ))
    fi

    ip_int=$(( (o1*16777216) + (o2*65536) + (o3*256) + o4 ))
    net_int=$(( ip_int & mask ))
    gw_int=$(( net_int + 1 ))
    n1=$(( (gw_int>>24)&255 )); n2=$(( (gw_int>>16)&255 ))
    n3=$(( (gw_int>>8)&255  )); n4=$(( gw_int&255 ))
    echo "${n1}.${n2}.${n3}.${n4}"
}

_get_gateway_for_iface() {
    local iface="$1"
    local gw iface_index

    iface_index=$(ip link show "$iface" 2>/dev/null | awk -F': ' 'NR==1{print $1}')

    for lease_dir in \
        /run/systemd/netif/leases /run/systemd/network \
        /run/systemd/netif /var/lib/systemd/network
    do
        [ -d "$lease_dir" ] || continue
        for f in \
            "$lease_dir/${iface_index}.lease" \
            "$lease_dir/${iface}.lease" \
            $(find "$lease_dir" -maxdepth 1 -name "*.lease" 2>/dev/null)
        do
            [ -f "$f" ] || continue
            gw=$(grep "^ROUTER=" "$f" 2>/dev/null \
                | cut -d'=' -f2 | tr ' ' '\n' \
                | grep -E '^[0-9]+\.[0-9]+\.[0-9]+\.[0-9]+$' | head -1)
            [ -n "$gw" ] && echo "$gw" && return 0
        done
        if [ -n "$iface_index" ] && [ -f "$lease_dir/$iface_index" ]; then
            gw=$(grep "^ROUTER=" "$lease_dir/$iface_index" 2>/dev/null \
                | cut -d'=' -f2 | head -1)
            [ -n "$gw" ] && echo "$gw" && return 0
        fi
    done

    gw=$(networkctl status "$iface" 2>/dev/null \
        | grep -i "gateway\|router" | awk '{print $NF}' \
        | grep -E '^[0-9]+\.[0-9]+\.[0-9]+\.[0-9]+$' | head -1)
    [ -n "$gw" ] && echo "$gw" && return 0

    gw=$(ip route show dev "$iface" 2>/dev/null | awk '/via/{print $3}' | head -1)
    [ -n "$gw" ] && echo "$gw" && return 0

    # Last resort: calculate network+1 from the interface CIDR
    local cidr ip pfx
    cidr=$(ip addr show "$iface" 2>/dev/null | grep "inet " | awk '{print $2}' | head -1)
    if [ -n "$cidr" ]; then
        ip=$(echo "$cidr" | cut -d'/' -f1)
        pfx=$(echo "$cidr" | cut -d'/' -f2)
        _calc_network_gateway "$ip" "$pfx"
        return 0
    fi

    echo ""; return 1
}

# ── Bridge interface discovery ────────────────────────────────────────────────

_get_lan_bridges() {
    ip link show type bridge 2>/dev/null \
        | awk -F': ' '/^[0-9]/{print $2}' \
        | awk '{print $1}'
}

# ── WAN subinterface rp_filter helper ────────────────────────────────────────
# UniFiOS creates subinterfaces on the WAN port for each WAN profile. Their
# rp_filter blocks return traffic from the voip VLAN if left at default (1).

_wan_subif_rp_set() {
    local sub cur
    for sub in $(ip link show 2>/dev/null \
            | awk -F'[ :@]' "/@${VOIP_WAN_INTERFACE}[: ]/{print \$3}" \
            | grep -v "^${VOIP_WAN_VLAN_INTERFACE}$"); do
        [ -z "$sub" ] && continue
        cur=$(cat "/proc/sys/net/ipv4/conf/${sub}/rp_filter" 2>/dev/null)
        [ "$cur" = "0" ] && continue
        echo 0 > "/proc/sys/net/ipv4/conf/${sub}/rp_filter" 2>/dev/null || true
        echo "  rp_filter  : set to 0 on $sub"
    done
}

_wan_subif_rp_fix() {
    local action="${1:-add}"
    local sub

    for sub in $(ip link show 2>/dev/null \
            | awk -F'[ :@]' "/@${VOIP_WAN_INTERFACE}[: ]/{print \$3}" \
            | grep -v "^${VOIP_WAN_VLAN_INTERFACE}$"); do
        [ -z "$sub" ] && continue
        if [ "$action" = "add" ]; then
            iptables -C FORWARD -i "$sub" \
                -m state --state RELATED,ESTABLISHED -j ACCEPT 2>/dev/null \
                || iptables -I FORWARD 1 -i "$sub" \
                    -m state --state RELATED,ESTABLISHED -j ACCEPT
        else
            iptables -D FORWARD -i "$sub" \
                -m state --state RELATED,ESTABLISHED -j ACCEPT 2>/dev/null || true
        fi
    done
}

# ── PBR routing ───────────────────────────────────────────────────────────────
# Creates a dedicated routing table so IMS-bound traffic uses the VoIP
# interface regardless of which WAN UniFiOS currently prefers.

_routing_setup_pbr() {
    local gw
    gw=$(_get_gateway_for_iface "$VOIP_WAN_VLAN_INTERFACE")
    [ -z "$gw" ] && echo "ERROR: cannot determine gateway" && return 1

    echo "  Mode       : pbr (policy-based routing)"
    echo "  Gateway    : $gw"
    echo "$gw" > "$VOIP_STATE_DIR/gw"

    # Register routing table name if not already present
    grep -q "^$VOIP_RT_TABLE " /etc/iproute2/rt_tables 2>/dev/null \
        || echo "$VOIP_RT_TABLE $VOIP_RT_TABLE_NAME" >> /etc/iproute2/rt_tables

    # Flush any stale rules/routes from a previous run
    ip rule del to   "$VOIP_DEST_SUBNET" priority 100 2>/dev/null || true
    ip rule del from "$VOIP_IP"          priority 100 2>/dev/null || true
    ip route flush table "$VOIP_RT_TABLE" 2>/dev/null || true
    local _setup_fwmark
    _setup_fwmark=$(iptables -t mangle -L PREROUTING -n 2>/dev/null \
        | awk '/MARK xset/{match($0,/0x[0-9a-f]+\/0x[0-9a-f]+/); \
               if(RSTART){print substr($0,RSTART,RLENGTH); exit}}')
    [ -z "$_setup_fwmark" ] && \
        _setup_fwmark=$(cat "$VOIP_STATE_DIR/fwmark" 2>/dev/null || echo "0x1e0000/0x7e0000")
    echo "$_setup_fwmark" > "$VOIP_STATE_DIR/fwmark"
    while iptables -t mangle -D PREROUTING \
        -d "$VOIP_DEST_SUBNET" -j MARK --set-xmark "$_setup_fwmark" 2>/dev/null; do :; done
    while iptables -t mangle -D PREROUTING \
        -d "$VOIP_DEST_SUBNET" -j CONNMARK --save-mark --nfmask 0x7e0000 2>/dev/null; do :; done
    while iptables -t mangle -D PREROUTING \
        -m connmark --mark "$_setup_fwmark" \
        -j CONNMARK --restore-mark --nfmask 0x7e0000 2>/dev/null; do :; done

    ip route add default via "$gw" dev "$VOIP_WAN_VLAN_INTERFACE" table "$VOIP_RT_TABLE"
    echo "  Table $VOIP_RT_TABLE    : default via $gw dev $VOIP_WAN_VLAN_INTERFACE"

    ip rule add to   "$VOIP_DEST_SUBNET" lookup "$VOIP_RT_TABLE" priority 100
    ip rule add from "$VOIP_IP"          lookup "$VOIP_RT_TABLE" priority 100
    echo "  Rules      : to $VOIP_DEST_SUBNET and from $VOIP_IP -> table $VOIP_RT_TABLE (priority 100)"

    # MARK+CONNMARK save for new outbound packets to the IMS subnet.
    # CONNMARK restore for ESTABLISHED reply packets — this keeps reply traffic
    # on the voip routing table even if conntrack is briefly disrupted, which
    # prevents mid-call audio muting when the watchdog restores rules.
    iptables -t mangle -I PREROUTING 1 \
        -d "$VOIP_DEST_SUBNET" -j MARK --set-xmark "$_setup_fwmark"
    iptables -t mangle -I PREROUTING 2 \
        -d "$VOIP_DEST_SUBNET" -j CONNMARK --save-mark --nfmask 0x7e0000
    iptables -t mangle -I PREROUTING 3 \
        -m connmark --mark "$_setup_fwmark" \
        -j CONNMARK --restore-mark --nfmask 0x7e0000
    echo "  Mangle     : PREROUTING dst $VOIP_DEST_SUBNET -> MARK + CONNMARK save/restore"

    iptables -t nat -C "$UBIOS_NAT_CHAIN" \
        -o "$VOIP_WAN_VLAN_INTERFACE" -j MASQUERADE 2>/dev/null \
    || iptables -t nat -A "$UBIOS_NAT_CHAIN" \
        -o "$VOIP_WAN_VLAN_INTERFACE" -j MASQUERADE
    echo "  NAT        : MASQUERADE in $UBIOS_NAT_CHAIN on $VOIP_WAN_VLAN_INTERFACE"

    # Do NOT insert raw FORWARD -j ACCEPT rules — those sit before UniFi's
    # IPS/ALIEN/TOR chains (rules 8-10) and the zone-based firewall (rule 11),
    # bypassing all security checks. Instead:
    #   - LAN clients: handled via UBIOS_LAN_IN_USER (UniFi's own LAN chain)
    #   - VPN clients: handled via UBIOS_VPN_WAN_USER (default ACCEPT for VPN->WAN)
    #   - Return traffic: handled by FORWARD rule 1 (global RELATED,ESTABLISHED)
    # This keeps ALIEN/TOR blocking and IPS in the FORWARD chain effective.
    _wan_subif_rp_set

    iptables -C UBIOS_LAN_IN_USER -d "$VOIP_DEST_SUBNET" -j ACCEPT 2>/dev/null \
        || iptables -I UBIOS_LAN_IN_USER 1 -d "$VOIP_DEST_SUBNET" -j ACCEPT
    echo "  FW ACCEPT  : UBIOS_LAN_IN_USER dst $VOIP_DEST_SUBNET"
    if [ -n "$VOIP_VPN_INTERFACES" ]; then
        echo "  VPN        : $VOIP_VPN_INTERFACES allowed via UBIOS_VPN_WAN_USER"
    fi
}


# ── Forward routing mode ──────────────────────────────────────────────────────
# Routes IMS-bound traffic from one or more configured interfaces through the
# voip routing table, steering it out via the voip WAN interface.  Uses the
# same fwmark / routing-table mechanism as PBR, but restricts the mangle MARK
# rules to traffic arriving on the configured interface(s) only, leaving all
# other LAN traffic on its default WAN path.

_routing_setup_forward() {
    if [ -z "$VOIP_FORWARD_INTERFACE" ]; then
        echo "ERROR: ROUTING_MODE=forward but VOIP_FORWARD_INTERFACE is not set"
        return 1
    fi

    # Validate every configured interface (VOIP_FORWARD_INTERFACE is space-separated)
    for _fwd_iface_chk in $VOIP_FORWARD_INTERFACE; do
        if ! ip link show "$_fwd_iface_chk" >/dev/null 2>&1; then
            echo "ERROR: forward interface $_fwd_iface_chk does not exist"
            return 1
        fi
    done

    local gw
    gw=$(_get_gateway_for_iface "$VOIP_WAN_VLAN_INTERFACE")
    [ -z "$gw" ] && \
        echo "ERROR: cannot determine gateway for $VOIP_WAN_VLAN_INTERFACE" && return 1

    echo "  Mode       : forward ($VOIP_FORWARD_INTERFACE -> $VOIP_WAN_VLAN_INTERFACE)"
    echo "  Gateway    : $gw"
    echo "$gw"                    > "$VOIP_STATE_DIR/gw"
    echo "$VOIP_FORWARD_INTERFACE" > "$VOIP_STATE_DIR/forward_iface"

    grep -q "^$VOIP_RT_TABLE " /etc/iproute2/rt_tables 2>/dev/null \
        || echo "$VOIP_RT_TABLE $VOIP_RT_TABLE_NAME" >> /etc/iproute2/rt_tables

    # ── Flush stale state ──────────────────────────────────────────────────
    ip route flush table "$VOIP_RT_TABLE" 2>/dev/null || true
    while ip rule del priority 101 2>/dev/null; do :; done

    # ── Routing table ──────────────────────────────────────────────────────
    ip route add "$VOIP_DEST_SUBNET" via "$gw" dev "$VOIP_WAN_VLAN_INTERFACE" \
        table "$VOIP_RT_TABLE"
    ip route add default             via "$gw" dev "$VOIP_WAN_VLAN_INTERFACE" \
        table "$VOIP_RT_TABLE"
    echo "  Table $VOIP_RT_TABLE    : $VOIP_DEST_SUBNET + default via $gw dev $VOIP_WAN_VLAN_INTERFACE"

    # ── IP rules ───────────────────────────────────────────────────────────
    # Routing is selected purely on (incoming interface, destination subnet) —
    # not on fwmark/connmark.  UniFiOS maintains its own CONNMARK save/restore
    # for multi-WAN policy routing using marks in the same range as ours; that
    # mark gets restored onto IMS reply packets regardless of anything this
    # daemon does.  A fwmark-based rule would then incorrectly match those
    # replies (dst = LAN client) and send them back out the voip interface.
    # An iif+to rule cannot match a reply packet (wrong iif, wrong dst), so
    # replies always fall through to the main table's existing route to the
    # forward interface.
    ip rule add from "$VOIP_IP" lookup "$VOIP_RT_TABLE" priority 99
    echo "  Rules      : from $VOIP_IP -> table $VOIP_RT_TABLE (priority 99)"
    for _iface in $VOIP_FORWARD_INTERFACE; do
        ip rule add iif "$_iface" to "$VOIP_DEST_SUBNET" lookup "$VOIP_RT_TABLE" priority 101
        echo "  Rules      : iif $_iface to $VOIP_DEST_SUBNET -> table $VOIP_RT_TABLE (priority 101)"
    done

    # ── NAT ────────────────────────────────────────────────────────────────
    iptables -t nat -C "$UBIOS_NAT_CHAIN" \
        -o "$VOIP_WAN_VLAN_INTERFACE" -j MASQUERADE 2>/dev/null \
    || iptables -t nat -A "$UBIOS_NAT_CHAIN" \
        -o "$VOIP_WAN_VLAN_INTERFACE" -j MASQUERADE
    echo "  NAT        : MASQUERADE in $UBIOS_NAT_CHAIN on $VOIP_WAN_VLAN_INTERFACE"

    _wan_subif_rp_set

    iptables -C UBIOS_LAN_IN_USER -d "$VOIP_DEST_SUBNET" -j ACCEPT 2>/dev/null \
        || iptables -I UBIOS_LAN_IN_USER 1 -d "$VOIP_DEST_SUBNET" -j ACCEPT
    echo "  FW ACCEPT  : UBIOS_LAN_IN_USER dst $VOIP_DEST_SUBNET"
    if [ -n "$VOIP_VPN_INTERFACES" ]; then
        echo "  VPN        : $VOIP_VPN_INTERFACES allowed via UBIOS_VPN_WAN_USER"
    fi
}


# ── B2BUA routing mode ────────────────────────────────────────────────────────
# Signaling-only SIP B2BUA (b2bua.py).  Sets up the voip routing table (203)
# so IMS-bound traffic — including the B2BUA process's upstream SIP, which
# sources from VOIP_IP — always exits via the voip interface.
# rp_filter=0 on WAN subinterfaces is required: the ISP sends INVITE responses
# via a different VLAN subinterface (e.g. eth4.12) than the registration VLAN.
# The Python process is started after routing is established; RTP flows
# peer-to-peer with no relay so no additional forwarding rules are needed.

_b2bua_start() {
    if [ -z "$VOIP_B2BUA_USER" ] || [ -z "$VOIP_B2BUA_PASS" ] || [ -z "$VOIP_B2BUA_DOMAIN" ]; then
        echo "  B2BUA  : ERROR — VOIP_B2BUA_USER, VOIP_B2BUA_PASS and VOIP_B2BUA_DOMAIN must be set"
        return 1
    fi
    if [ ! -f /data/voip/b2bua.py ]; then
        echo "  B2BUA  : ERROR — /data/voip/b2bua.py not found"
        return 1
    fi
    local pcscf_ip
    pcscf_ip=$(cat "$VOIP_STATE_DIR/pcscf_ip" 2>/dev/null | grep -v unresolved || echo "")
    [ -z "$pcscf_ip" ] && pcscf_ip="$PCSCF_HOSTNAME"
    echo "  B2BUA  : starting (${VOIP_B2BUA_USER}@${VOIP_B2BUA_DOMAIN} via ${pcscf_ip})"
    B2BUA_PROXY="$pcscf_ip"           \
    B2BUA_DOMAIN="$VOIP_B2BUA_DOMAIN" \
    B2BUA_USER="$VOIP_B2BUA_USER"     \
    B2BUA_PASS="$VOIP_B2BUA_PASS"     \
    B2BUA_VOIP_IP="$VOIP_IP"          \
    B2BUA_LOCAL_PORT="$VOIP_B2BUA_LISTEN_PORT" \
    B2BUA_LOCAL_USER="$VOIP_B2BUA_LOCAL_USER"  \
    B2BUA_LOCAL_PASS="$VOIP_B2BUA_LOCAL_PASS"  \
    B2BUA_REG_EXPIRES="$VOIP_B2BUA_REG_EXPIRES" \
    B2BUA_STATE_DIR="$VOIP_STATE_DIR" \
    B2BUA_DEBUG="$VOIP_DEBUG"         \
    python3 /data/voip/b2bua.py >> "$VOIP_STATE_DIR/b2bua.log" 2>&1 &
    echo $! > "$VOIP_STATE_DIR/b2bua_pid"
    echo "  B2BUA  : PID $(cat $VOIP_STATE_DIR/b2bua_pid)"
}

_b2bua_stop() {
    if [ -f "$VOIP_STATE_DIR/b2bua_pid" ]; then
        local pid
        pid=$(cat "$VOIP_STATE_DIR/b2bua_pid")
        kill "$pid" 2>/dev/null || true
        rm -f "$VOIP_STATE_DIR/b2bua_pid" "$VOIP_STATE_DIR/b2bua_status"
        echo "  B2BUA  : stopped (PID $pid)"
    fi
}

# ── B2BUA NETNS (veth/network-namespace) functions ──────────────────────────
# These implement the b2bua_netns routing mode which runs the B2BUA inside
# a Linux network namespace.  Upstream SIP/RTP exits as FORWARD traffic
# (namespace → b2bua_v0 → voip), so ALIEN/TOR blocking and IPS apply
# unconditionally.  The voip interface is not auto-zoned by UniFi so
# zone-specific rules do not apply, but ALIEN and IPS are zone-independent.
# Requires PCSCF_HOSTNAME to be set (used to determine the IMS subnet).

_b2bua_netns_start() {
    if [ -z "$VOIP_B2BUA_USER" ] || [ -z "$VOIP_B2BUA_PASS" ] || [ -z "$VOIP_B2BUA_DOMAIN" ]; then
        echo "  B2BUA  : ERROR — VOIP_B2BUA_USER, VOIP_B2BUA_PASS and VOIP_B2BUA_DOMAIN must be set"
        return 1
    fi
    if [ ! -f /data/voip/b2bua.py ]; then
        echo "  B2BUA  : ERROR — /data/voip/b2bua.py not found"
        return 1
    fi
    
    # 1. Setup Sandbox Network Namespace
    ip netns add b2bua_ns 2>/dev/null || true
    ip link add b2bua_v0 type veth peer name b2bua_v1 2>/dev/null || true
    ip link set b2bua_v1 netns b2bua_ns 2>/dev/null || true

    # 2. Configure Host Side (Main Router)
    ip addr add 172.31.255.1/30 dev b2bua_v0 2>/dev/null || true
    ip link set b2bua_v0 up 2>/dev/null || true

    # 3. Configure Sandbox Side
    ip netns exec b2bua_ns ip addr add 172.31.255.2/30 dev b2bua_v1 2>/dev/null || true
    ip netns exec b2bua_ns ip link set b2bua_v1 up 2>/dev/null || true
    ip netns exec b2bua_ns ip link set lo up 2>/dev/null || true
    ip netns exec b2bua_ns ip route add default via 172.31.255.1 2>/dev/null || true
    # Ensure no VOIP_IP alias exists on b2bua_v1 — if it does, the kernel
    # picks it as source (same /8 as IMS), MASQUERADE won't fire, and
    # conntrack creates no NAT entry so IMS replies find no socket.
    ip netns exec b2bua_ns ip addr del "$VOIP_IP/32" dev b2bua_v1 2>/dev/null || true

    local pcscf_ip
    pcscf_ip=$(cat "$VOIP_STATE_DIR/pcscf_ip" 2>/dev/null | grep -v unresolved || echo "")
    [ -z "$pcscf_ip" ] && pcscf_ip="$PCSCF_HOSTNAME"
    echo "  B2BUA  : starting sandbox (${VOIP_B2BUA_USER}@${VOIP_B2BUA_DOMAIN} via ${pcscf_ip})"
    
    env B2BUA_PROXY="$pcscf_ip" \
    B2BUA_DOMAIN="$VOIP_B2BUA_DOMAIN" \
    B2BUA_USER="$VOIP_B2BUA_USER" \
    B2BUA_PASS="$VOIP_B2BUA_PASS" \
    B2BUA_VOIP_IP="$VOIP_IP" \
    B2BUA_LOCAL_PORT="$VOIP_B2BUA_LISTEN_PORT" \
    B2BUA_LOCAL_USER="$VOIP_B2BUA_LOCAL_USER" \
    B2BUA_LOCAL_PASS="$VOIP_B2BUA_LOCAL_PASS" \
    B2BUA_REG_EXPIRES="$VOIP_B2BUA_REG_EXPIRES" \
    B2BUA_STATE_DIR="$VOIP_STATE_DIR" \
    B2BUA_DEBUG="$VOIP_DEBUG" \
    B2BUA_WAN_IFACE="$VOIP_WAN_VLAN_INTERFACE" \
    B2BUA_NETNS="true" \
    B2BUA_LAN_IP="$(ip -o -4 addr show dev br0 2>/dev/null | awk '{print $4}' | cut -d/ -f1 | head -1)" \
    ip netns exec b2bua_ns python3 /data/voip/b2bua.py >> "$VOIP_STATE_DIR/b2bua.log" 2>&1 &
    
    echo $! > "$VOIP_STATE_DIR/b2bua_pid"
    echo "  B2BUA  : PID $(cat $VOIP_STATE_DIR/b2bua_pid) (Sandbox IP: 172.31.255.2)"
}

_b2bua_netns_stop() {
    if [ -f "$VOIP_STATE_DIR/b2bua_pid" ]; then
        local pid
        pid=$(cat "$VOIP_STATE_DIR/b2bua_pid")
        kill "$pid" 2>/dev/null || true
        # Wait for process to fully exit before destroying namespace/veth
        local _w=0
        while kill -0 "$pid" 2>/dev/null && [ $_w -lt 5 ]; do
            sleep 1; _w=$((_w+1))
        done
        rm -f "$VOIP_STATE_DIR/b2bua_pid" "$VOIP_STATE_DIR/b2bua_status"
        echo "  B2BUA  : stopped (PID $pid)"
    fi
    ip link del b2bua_v0 2>/dev/null || true
    ip netns del b2bua_ns 2>/dev/null || true
}

_routing_setup_b2bua_netns() {
    local gw
    gw=$(_get_gateway_for_iface "$VOIP_WAN_VLAN_INTERFACE")
    [ -z "$gw" ] && echo "ERROR: cannot determine gateway" && return 1

    echo "  Mode       : b2bua_netns (Sandboxed SIP proxy)"
    echo "  Gateway    : $gw"
    echo "$gw" > "$VOIP_STATE_DIR/gw"

    # ── 1. Routing voip routing table ─────────────────────────────────────────────────
    grep -q "^$VOIP_RT_TABLE " /etc/iproute2/rt_tables 2>/dev/null \
        || echo "$VOIP_RT_TABLE $VOIP_RT_TABLE_NAME" >> /etc/iproute2/rt_tables

    ip route flush table "$VOIP_RT_TABLE" 2>/dev/null || true
    ip route add "$VOIP_DEST_SUBNET" via "$gw" dev "$VOIP_WAN_VLAN_INTERFACE" table "$VOIP_RT_TABLE"
    ip route add 172.31.255.0/30 dev b2bua_v0 table "$VOIP_RT_TABLE" 2>/dev/null || true
    ip route add 172.31.255.0/30 dev b2bua_v0 2>/dev/null || true
    echo "  Table $VOIP_RT_TABLE    : $VOIP_DEST_SUBNET via $gw + 172.31.255.0/30 dev b2bua_v0"

    # ── 2. IP rules — subnet only in route table, never in ip rule ───────────
    # Clean stale rules from all previous variants
    ip rule del from 172.31.255.2                        priority 100 2>/dev/null || true
    ip rule del from 172.31.255.2 to "$VOIP_DEST_SUBNET" priority 100 2>/dev/null || true
    ip rule del iif b2bua_v0                             priority 100 2>/dev/null || true
    ip rule del to   "$VOIP_DEST_SUBNET"                 priority 100 2>/dev/null || true
    ip rule del from "$VOIP_IP"                          priority 99  2>/dev/null || true
    ip rule del from "$VOIP_IP" to "$VOIP_DEST_SUBNET"   priority 99  2>/dev/null || true
    ip rule del from "$VOIP_IP"                          priority 100 2>/dev/null || true
    ip rule del fwmark 0x1e0000/0x1e0000 lookup "$VOIP_RT_TABLE" priority 100 2>/dev/null || true
    ip rule del fwmark 0x1e0000/0x7e0000 lookup "$VOIP_RT_TABLE" priority 101 2>/dev/null || true

    # iif b2bua_v0: netns SIP traffic → voip routing table
    ip rule add iif b2bua_v0 lookup "$VOIP_RT_TABLE" priority 100
    # from VOIP_IP: upstream SIP source address → voip routing table
    ip rule add from "$VOIP_IP" lookup "$VOIP_RT_TABLE" priority 99

    echo "  Rules      : iif b2bua_v0 -> table $VOIP_RT_TABLE (p100)"
    echo "  Rules      : from $VOIP_IP -> table $VOIP_RT_TABLE (p99)"

    # LAN/VPN client RTP to IMS needs a route in the main table.
    # LAN RTP does not originate from b2bua_v0 or from VOIP_IP, so neither
    # of the two ip rules above match — it falls through to the main table.
    # A single subnet route here is sufficient; no per-call routes needed.
    ip route add "$VOIP_DEST_SUBNET" via "$gw" dev "$VOIP_WAN_VLAN_INTERFACE" 2>/dev/null || true
    echo "  Main table : $VOIP_DEST_SUBNET via $gw dev $VOIP_WAN_VLAN_INTERFACE (LAN RTP)"

    # ── 3. Mangle ────────────────────────────────────────────────────────────
    # UniFiOS already installs MARK + CONNMARK save/restore rules for the voip
    # table. We do NOT add duplicates.

    # WAN subif CT --notrack/DNAT not needed: with B2BUA_NETNS=true the b2bua
    # binds to 0.0.0.0, sends from 172.31.255.2, MASQUERADE rewrites to VOIP_IP,
    # and conntrack's reverse NAT automatically delivers IMS replies back to
    # 172.31.255.2 inside the netns — regardless of which WAN subif they arrive on.

    # ── 4. NAT ───────────────────────────────────────────────────────────────
    # DNAT: all SIP to any local address → b2bua netns.
    # so this single pair of rules handles:
    # ! -i b2bua_v0 prevents the netns reply traffic from looping back.
    iptables -t nat -I PREROUTING 1 ! -i b2bua_v0 -p udp \
        --dport "$VOIP_B2BUA_LISTEN_PORT" -m addrtype --dst-type LOCAL \
        -j DNAT --to-destination 172.31.255.2
    iptables -t nat -I PREROUTING 1 ! -i b2bua_v0 -p tcp \
        --dport "$VOIP_B2BUA_LISTEN_PORT" -m addrtype --dst-type LOCAL \
        -j DNAT --to-destination 172.31.255.2
    # MASQUERADE: namespace→voip (IMS must see VOIP_IP — MASQUERADE uses the
    # voip interface IP = VOIP_IP; this survives UniFiOS iptables rewrites via
    # UBIOS_POSTROUTING_USER_HOOK, unlike a direct POSTROUTING SNAT rule)
    # Also: namespace→LAN (so BYE/responses appear from the correct gateway IP)
    iptables -t nat -C "$UBIOS_NAT_CHAIN" \
        -o "$VOIP_WAN_VLAN_INTERFACE" -j MASQUERADE 2>/dev/null \
    || iptables -t nat -A "$UBIOS_NAT_CHAIN" \
        -o "$VOIP_WAN_VLAN_INTERFACE" -j MASQUERADE
    iptables -t nat -C "$UBIOS_NAT_CHAIN" \
        -s 172.31.255.2 ! -o "$VOIP_WAN_VLAN_INTERFACE" -j MASQUERADE 2>/dev/null \
    || iptables -t nat -A "$UBIOS_NAT_CHAIN" \
        -s 172.31.255.2 ! -o "$VOIP_WAN_VLAN_INTERFACE" -j MASQUERADE
    echo "  NAT        : DNAT :$VOIP_B2BUA_LISTEN_PORT -> 172.31.255.2"
    echo "  NAT        : SNAT 172.31.255.2 -> $VOIP_IP on $VOIP_WAN_VLAN_INTERFACE"

    # ── 5. FORWARD rules for b2bua_v0 veth ────────────────────────────────
    # b2bua_v0 is not assigned to any UniFi zone (custom veth pairs never
    # are).  These rules permit traffic through the FORWARD chain in both
    # directions.  They sit AFTER the unconditional ALIEN and IPS targets
    # so threat intelligence and IPS still apply to this traffic first.
    iptables -C FORWARD -i b2bua_v0 -j ACCEPT 2>/dev/null \
        || iptables -A FORWARD -i b2bua_v0 -j ACCEPT
    iptables -C FORWARD -o b2bua_v0 -j ACCEPT 2>/dev/null \
        || iptables -A FORWARD -o b2bua_v0 -j ACCEPT
    _wan_subif_rp_set
    
    # Block LAN clients from reaching IMS SIP (port 5060) directly.
    # Without this, clients that resolve the IMS domain directly bypass the
    # b2bua entirely — breaking inbound forking, auth, and call state.
    # RTP is unaffected (different ports, peer-to-peer by design).
    iptables -C FORWARD ! -i b2bua_v0 -d "$VOIP_DEST_SUBNET" -p udp \
        --dport "$VOIP_B2BUA_LISTEN_PORT" -j DROP 2>/dev/null \
    || iptables -I FORWARD 1 ! -i b2bua_v0 -d "$VOIP_DEST_SUBNET" -p udp \
        --dport "$VOIP_B2BUA_LISTEN_PORT" -j DROP
    iptables -C FORWARD ! -i b2bua_v0 -d "$VOIP_DEST_SUBNET" -p tcp \
        --dport "$VOIP_B2BUA_LISTEN_PORT" -j DROP 2>/dev/null \
    || iptables -I FORWARD 1 ! -i b2bua_v0 -d "$VOIP_DEST_SUBNET" -p tcp \
        --dport "$VOIP_B2BUA_LISTEN_PORT" -j DROP
    echo "  FW DROP    : FORWARD !b2bua_v0 dst $VOIP_DEST_SUBNET port $VOIP_B2BUA_LISTEN_PORT (force b2bua)"
    
    # Crucial for B2BUA: Prevent rp_filter from dropping incoming IMS SIP responses
    echo 0 > "/proc/sys/net/ipv4/conf/$VOIP_WAN_VLAN_INTERFACE/rp_filter" 2>/dev/null || true
    echo "  rp_filter  : Disabled on $VOIP_WAN_VLAN_INTERFACE for incoming IMS SIP responses"

    iptables -C UBIOS_LAN_IN_USER -d 172.31.255.2 -j ACCEPT 2>/dev/null \
        || iptables -I UBIOS_LAN_IN_USER 1 -d 172.31.255.2 -j ACCEPT
    echo "  FW ACCEPT  : UBIOS_LAN_IN_USER dst 172.31.255.2"
    echo "  Sandbox routing complete."
}

_routing_setup_b2bua() {
    local gw
    gw=$(_get_gateway_for_iface "$VOIP_WAN_VLAN_INTERFACE")
    [ -z "$gw" ] && echo "ERROR: cannot determine gateway" && return 1

    echo "  Mode       : b2bua (signaling-only SIP proxy)"
    echo "  Gateway    : $gw"
    echo "$gw" > "$VOIP_STATE_DIR/gw"

    # Uses the voip routing table (VOIP_RT_TABLE) — the ip rule 'from $VOIP_IP
    # lookup $VOIP_RT_TABLE' ensures upstream SIP sourced from VOIP_IP exits
    # via the voip interface.  MARK/CONNMARK handles LAN clients' RTP the same way.
    grep -q "^$VOIP_RT_TABLE " /etc/iproute2/rt_tables 2>/dev/null \
        || echo "$VOIP_RT_TABLE $VOIP_RT_TABLE_NAME" >> /etc/iproute2/rt_tables

    # Flush any stale state from a previous run
    ip rule del to   "$VOIP_DEST_SUBNET" priority 100 2>/dev/null || true
    ip rule del from "$VOIP_IP"          priority 100 2>/dev/null || true
    ip rule del fwmark 0x1e0000/0x7e0000 lookup "$VOIP_RT_TABLE" priority 101 2>/dev/null || true
    ip route flush table "$VOIP_RT_TABLE" 2>/dev/null || true
    while iptables -t mangle -D PREROUTING \
        -d "$VOIP_DEST_SUBNET" -p udp --dport 5060 -j RETURN 2>/dev/null; do :; done
    while iptables -t mangle -D PREROUTING \
        -d "$VOIP_DEST_SUBNET" -p tcp --dport 5060 -j RETURN 2>/dev/null; do :; done
    local _setup_fwmark
    _setup_fwmark=$(iptables -t mangle -L PREROUTING -n 2>/dev/null \
        | awk '/MARK xset/{match($0,/0x[0-9a-f]+\/0x[0-9a-f]+/); \
               if(RSTART){print substr($0,RSTART,RLENGTH); exit}}')
    [ -z "$_setup_fwmark" ] && \
        _setup_fwmark=$(cat "$VOIP_STATE_DIR/fwmark" 2>/dev/null || echo "0x1e0000/0x7e0000")
    echo "$_setup_fwmark" > "$VOIP_STATE_DIR/fwmark"
    while iptables -t mangle -D PREROUTING \
        -d "$VOIP_DEST_SUBNET" -j MARK --set-xmark "$_setup_fwmark" 2>/dev/null; do :; done
    while iptables -t mangle -D PREROUTING \
        -d "$VOIP_DEST_SUBNET" -j CONNMARK --save-mark --nfmask 0x7e0000 2>/dev/null; do :; done
    while iptables -t mangle -D PREROUTING \
        -m connmark --mark "$_setup_fwmark" \
        -j CONNMARK --restore-mark --nfmask 0x7e0000 2>/dev/null; do :; done

    ip route add default via "$gw" dev "$VOIP_WAN_VLAN_INTERFACE" table "$VOIP_RT_TABLE"
    echo "  Table $VOIP_RT_TABLE    : default via $gw dev $VOIP_WAN_VLAN_INTERFACE"

    # B2BUA mode intentionally omits 'ip rule to IMS_SUBNET lookup voip'.
    # That rule would give every LAN client a routed path to the IMS regardless
    # of firewall zones.  Instead:
    #   - 'from VOIP_IP'  routes only the B2BUA process's own upstream SIP
    #   - 'fwmark'        routes marked packets (RTP, established flows)
    # Port 5060 is excluded from marking (RETURN rules below), so a LAN client
    # attempting direct IMS SIP gets no route and fails naturally — no DROP rules
    # needed anywhere.
    ip rule add from "$VOIP_IP" lookup "$VOIP_RT_TABLE" priority 100
    ip rule add fwmark "$_setup_fwmark" lookup "$VOIP_RT_TABLE" priority 101
    echo "  Rules      : from $VOIP_IP -> table $VOIP_RT_TABLE (priority 100)"
    echo "  Rules      : fwmark $_setup_fwmark -> table $VOIP_RT_TABLE (priority 101)"

    # RETURN port 5060 before MARK — unmarked SIP has no route to the IMS subnet
    # from a LAN client.  All other traffic (RTP on high ports) is marked normally.
    iptables -t mangle -I PREROUTING 1 \
        -d "$VOIP_DEST_SUBNET" -p udp --dport 5060 -j RETURN
    iptables -t mangle -I PREROUTING 2 \
        -d "$VOIP_DEST_SUBNET" -p tcp --dport 5060 -j RETURN
    iptables -t mangle -I PREROUTING 3 \
        -d "$VOIP_DEST_SUBNET" -j MARK --set-xmark "$_setup_fwmark"
    iptables -t mangle -I PREROUTING 4 \
        -d "$VOIP_DEST_SUBNET" -j CONNMARK --save-mark --nfmask 0x7e0000
    iptables -t mangle -I PREROUTING 5 \
        -m connmark --mark "$_setup_fwmark" \
        -j CONNMARK --restore-mark --nfmask 0x7e0000
    echo "  Mangle     : RETURN port 5060 to $VOIP_DEST_SUBNET (no mark = no route for LAN)"
    echo "  Mangle     : MARK+CONNMARK other traffic to $VOIP_DEST_SUBNET (RTP)"

    iptables -t nat -C "$UBIOS_NAT_CHAIN" \
        -o "$VOIP_WAN_VLAN_INTERFACE" -j MASQUERADE 2>/dev/null \
    || iptables -t nat -A "$UBIOS_NAT_CHAIN" \
        -o "$VOIP_WAN_VLAN_INTERFACE" -j MASQUERADE
    echo "  NAT        : MASQUERADE in $UBIOS_NAT_CHAIN on $VOIP_WAN_VLAN_INTERFACE"

    _wan_subif_rp_set

    iptables -C UBIOS_LAN_IN_USER -d "$VOIP_DEST_SUBNET" -j ACCEPT 2>/dev/null \
        || iptables -I UBIOS_LAN_IN_USER 1 -d "$VOIP_DEST_SUBNET" -j ACCEPT
    echo "  FW ACCEPT  : UBIOS_LAN_IN_USER dst $VOIP_DEST_SUBNET (RTP)"
}


# ── Routing dispatcher ────────────────────────────────────────────────────────

_routing_setup() {
    # fresh=true  → called on initial start: flush conntrack + route cache
    # fresh=false → called as a restore (e.g. from ip-monitor or watchdog):
    #               skip conntrack flush to avoid disrupting active RTP calls
    local fresh="${1:-true}"
    echo "Setting up VoIP routing"
    _detect_voip_config || return 1
    case "$ROUTING_MODE" in
        pbr)          _routing_setup_pbr          || return 1 ;;
        forward)      _routing_setup_forward      || return 1 ;;
        b2bua)        _routing_setup_b2bua        || return 1 ;;
        b2bua_netns)  _routing_setup_b2bua_netns  || return 1 ;;
        *) echo "ERROR: unknown ROUTING_MODE '$ROUTING_MODE'"; return 1 ;;
    esac
    if [ "$fresh" = "true" ]; then
        # Fresh start only: flush conntrack so stale entries don't steer traffic
        # through the old (pre-voip) path. Skipped on restore to avoid killing
        # active RTP sessions (which causes mid-call audio muting).
        conntrack -D --orig-dst  "$VOIP_DEST_SUBNET" 2>/dev/null || true
        conntrack -D --reply-dst "$VOIP_DEST_SUBNET" 2>/dev/null || true
    fi
    ip route flush cache 2>/dev/null || true
}

_routing_teardown() {
    # Universal teardown — removes every rule, route, and artifact from every
    # routing mode.  All operations are idempotent (2>/dev/null || true), so
    # calling this regardless of which mode was previously active is safe.
    echo "Removing VoIP routing"
    local _td_fwmark _td_subnet _td_voip_ip _td_port
    _td_fwmark=$(cat  "$VOIP_STATE_DIR/fwmark"  2>/dev/null || echo "0x1e0000/0x7e0000")
    _td_subnet=$(cat  "$VOIP_STATE_DIR/subnet"  2>/dev/null || echo "${VOIP_DEST_SUBNET:-10.0.0.0/8}")
    _td_voip_ip=$(cat "$VOIP_STATE_DIR/voip_ip" 2>/dev/null || echo "")
    _td_port="${VOIP_B2BUA_LISTEN_PORT:-5060}"

    # ── Stop B2BUA process if running ──────────────────────────────────────
    if [ -f "$VOIP_STATE_DIR/b2bua_pid" ]; then
        kill "$(cat $VOIP_STATE_DIR/b2bua_pid)" 2>/dev/null || true
        sleep 1
        rm -f "$VOIP_STATE_DIR/b2bua_pid" "$VOIP_STATE_DIR/b2bua_status"
    fi

    # ── ip rules (all priorities, all modes) ───────────────────────────────
    ip rule del priority 98  2>/dev/null || true          # legacy netns fwmark
    ip rule del priority 99  2>/dev/null || true
    while ip rule del priority 100 2>/dev/null; do :; done
    while ip rule del priority 101 2>/dev/null; do :; done
    ip rule del fwmark "$_td_fwmark"       lookup "$VOIP_RT_TABLE" 2>/dev/null || true
    ip rule del fwmark 0x1e0000/0x7e0000   lookup "$VOIP_RT_TABLE" 2>/dev/null || true
    ip rule del fwmark 0x1e0000/0x1e0000   lookup "$VOIP_RT_TABLE" 2>/dev/null || true

    # ── Routing table + rt_tables entry ────────────────────────────────────
    ip route flush table "$VOIP_RT_TABLE"                  2>/dev/null || true
    sed -i "/^$VOIP_RT_TABLE /d" /etc/iproute2/rt_tables  2>/dev/null || true

    # ── Main-table routes (b2bua_netns LAN RTP route, forward mode route) ──
    ip route del "$_td_subnet"                             2>/dev/null || true
    ip route del 172.31.255.0/30 dev b2bua_v0             2>/dev/null || true

    # ── Netns / veth (b2bua_netns) ─────────────────────────────────────────
    ip link del b2bua_v0                                   2>/dev/null || true
    ip netns del b2bua_ns                                  2>/dev/null || true

    # ── mangle MARK / CONNMARK (pbr, b2bua) ───────────────────────────────
    while iptables -t mangle -D PREROUTING \
        -d "$_td_subnet" -j MARK --set-xmark "$_td_fwmark" 2>/dev/null; do :; done
    while iptables -t mangle -D PREROUTING \
        -d "$_td_subnet" -j MARK --set-xmark 0x1e0000/0x7e0000 2>/dev/null; do :; done
    while iptables -t mangle -D PREROUTING \
        -d "$_td_subnet" -j CONNMARK --save-mark --nfmask 0x7e0000 2>/dev/null; do :; done

    # Legacy cleanup: earlier forward-mode versions added per-interface
    # iif-restricted MARK/CONNMARK mangle rules.  The current implementation
    # no longer uses these (see _routing_setup_forward), but this cleanup
    # remains so routers upgrading from an older version start with a clean
    # mangle table.
    local _td_fwd_iface
    _td_fwd_iface=$(cat "$VOIP_STATE_DIR/forward_iface" 2>/dev/null || echo "$VOIP_FORWARD_INTERFACE")
    for _iface in $_td_fwd_iface; do
        while iptables -t mangle -D PREROUTING \
            -i "$_iface" -d "$_td_subnet" \
            -j MARK --set-xmark "$_td_fwmark" 2>/dev/null; do :; done
        while iptables -t mangle -D PREROUTING \
            -i "$_iface" -d "$_td_subnet" \
            -j CONNMARK --save-mark --nfmask 0x7e0000 2>/dev/null; do :; done
    done
    while iptables -t mangle -D PREROUTING \
        -m connmark --mark "$_td_fwmark" \
        -j CONNMARK --restore-mark --nfmask 0x7e0000 2>/dev/null; do :; done
    while iptables -t mangle -D PREROUTING \
        -m connmark --mark 0x1e0000/0x7e0000 \
        -j CONNMARK --restore-mark --nfmask 0x7e0000 2>/dev/null; do :; done

    # ── mangle RETURN (b2bua — blocks direct LAN SIP) ──────────────────────
    for _proto in udp tcp; do
        while iptables -t mangle -D PREROUTING \
            -d "$_td_subnet" -p "$_proto" --dport "$_td_port" \
            -j RETURN 2>/dev/null; do :; done
    done

    # ── nat DNAT (b2bua_netns) — current and legacy variants ───────────────
    for _proto in udp tcp; do
        for _i in 1 2 3; do
            iptables -t nat -D PREROUTING ! -i b2bua_v0 \
                -p "$_proto" --dport "$_td_port" \
                -m addrtype --dst-type LOCAL \
                -j DNAT --to-destination 172.31.255.2  2>/dev/null || true
            iptables -t nat -D PREROUTING \
                -p "$_proto" --dport "$_td_port" \
                -m addrtype --dst-type LOCAL \
                -j DNAT --to-destination 172.31.255.2  2>/dev/null || true
        done
    done
    for _i in 1 2 3; do
        iptables -t nat -D PREROUTING -i "$VOIP_WAN_VLAN_INTERFACE" \
            -p udp --dport "$_td_port" \
            -j DNAT --to-destination 172.31.255.2      2>/dev/null || true
        iptables -t nat -D PREROUTING \
            -p udp --dport "$_td_port" \
            -j DNAT --to-destination 172.31.255.2      2>/dev/null || true
    done

    # ── nat MASQUERADE / SNAT ──────────────────────────────────────────────
    while iptables -t nat -D "$UBIOS_NAT_CHAIN" \
        -o "$VOIP_WAN_VLAN_INTERFACE" -j MASQUERADE 2>/dev/null; do :; done
    # forward mode: MASQUERADE was on VOIP_FORWARD_INTERFACE, not the voip vlan
    if [ -n "$VOIP_FORWARD_INTERFACE" ]; then
        while iptables -t nat -D "$UBIOS_NAT_CHAIN" \
            -o "$VOIP_FORWARD_INTERFACE" -d "$_td_subnet" \
            -j MASQUERADE 2>/dev/null; do :; done
    fi
    for _i in 1 2 3; do
        iptables -t nat -D "$UBIOS_NAT_CHAIN" \
            -s 172.31.255.2 ! -o "$VOIP_WAN_VLAN_INTERFACE" \
            -j MASQUERADE                              2>/dev/null || true
        iptables -t nat -D POSTROUTING \
            -s 172.31.255.2 -j MASQUERADE             2>/dev/null || true
        iptables -t nat -D POSTROUTING \
            -s 172.31.255.2 -o "$VOIP_WAN_VLAN_INTERFACE" \
            -j SNAT --to-source "$_td_voip_ip"        2>/dev/null || true
    done

    # ── FORWARD accept/drop (b2bua_netns) ─────────────────────────────────
    for _i in 1 2 3; do
        iptables -D FORWARD -i b2bua_v0 -j ACCEPT     2>/dev/null || true
        iptables -D FORWARD -o b2bua_v0 -j ACCEPT     2>/dev/null || true
        for _proto in udp tcp; do
            iptables -D FORWARD ! -i b2bua_v0 -d "$VOIP_DEST_SUBNET" \
                -p "$_proto" --dport "$_td_port" -j DROP 2>/dev/null || true
            iptables -D FORWARD ! -i b2bua_v0 -d "$_td_subnet" \
                -p "$_proto" --dport "$_td_port" -j DROP 2>/dev/null || true
            iptables -D FORWARD -d "$_td_subnet" \
                -p "$_proto" --dport "$_td_port" -j DROP 2>/dev/null || true
        done
    done

    # ── raw CT notrack (legacy b2bua_netns) ────────────────────────────────
    iptables -t raw -D PREROUTING \
        -p udp --dport "$_td_port" -j CT --notrack    2>/dev/null || true

    # ── UBIOS_LAN_IN_USER accept rules ─────────────────────────────────────
    while iptables -D UBIOS_LAN_IN_USER \
        -d "$_td_subnet" -j ACCEPT 2>/dev/null; do :; done
    while iptables -D UBIOS_LAN_IN_USER \
        -d 172.31.255.2 -j ACCEPT 2>/dev/null; do :; done

    ip route flush cache 2>/dev/null || true

    # Flush stale conntrack entries for the B2BUA port.
    # Stale entries from a previous mode (carrying wrong NAT state or marks set
    # by earlier mangle rules) persist across mode switches and keep being
    # refreshed by client retransmissions, preventing the new DNAT rules from
    # ever establishing fresh conntrack state.  This is the root cause of the
    # "works after a few hours" symptom — entries finally expire on their own.
    local _ct_port="${VOIP_B2BUA_LISTEN_PORT:-5060}"
    conntrack -D -p udp --dport "$_ct_port" 2>/dev/null || true
    conntrack -D -p tcp --dport "$_ct_port" 2>/dev/null || true
    conntrack -D -p udp --sport "$_ct_port" 2>/dev/null || true
    conntrack -D -p tcp --sport "$_ct_port" 2>/dev/null || true
}

# ── P-CSCF resolution ─────────────────────────────────────────────────────────
# Called after routing is set up to confirm/refresh the P-CSCF address.
# On normal startup _detect_voip_config already resolved and saved the IP, so
# this function just verifies it. On WAN recovery it re-resolves from scratch.

_resolve_pcscf() {
    [ -z "$PCSCF_HOSTNAME" ] && return 0

    # If _detect_voip_config already resolved it successfully, nothing to do.
    local existing
    existing=$(cat "$VOIP_STATE_DIR/pcscf_ip" 2>/dev/null || echo "")
    if echo "$existing" | grep -qE '^[0-9]+\.[0-9]+\.[0-9]+\.[0-9]+$'; then
        echo "  P-CSCF: $existing (already resolved)"
        return 0
    fi

    # State file is missing or contains "(unresolved)" — re-resolve now.
    # This path is taken on WAN recovery where _detect_voip_config ran while
    # routing was already active (no temp-route trick needed).
    echo "Resolving $PCSCF_HOSTNAME..."
    sleep 3

    local pcscf_ip
    pcscf_ip=$(_resolve_pcscf_ip)

    if [ -n "$pcscf_ip" ]; then
        echo "  P-CSCF: $pcscf_ip"
        echo "$pcscf_ip" > "$VOIP_STATE_DIR/pcscf_ip"
    else
        echo "  WARNING: could not resolve $PCSCF_HOSTNAME"
        echo "(unresolved)" > "$VOIP_STATE_DIR/pcscf_ip"
    fi
}

# ── Status ────────────────────────────────────────────────────────────────────

_show_status() {
    local voip_ip subnet pcscf_ip gw mode_info
    voip_ip=$(cat  "$VOIP_STATE_DIR/voip_ip"  2>/dev/null || echo "unknown")
    subnet=$(cat   "$VOIP_STATE_DIR/subnet"   2>/dev/null || echo "unknown")
    pcscf_ip=$(cat "$VOIP_STATE_DIR/pcscf_ip" 2>/dev/null || echo "(unresolved)")
    gw=$(cat       "$VOIP_STATE_DIR/gw"       2>/dev/null || echo "unknown")

    case "$ROUTING_MODE" in
        pbr)     mode_info="PBR -> table $VOIP_RT_TABLE ($VOIP_RT_TABLE_NAME)" ;;
        forward) mode_info="Forward via $(cat $VOIP_STATE_DIR/forward_iface 2>/dev/null || echo $VOIP_FORWARD_INTERFACE)" ;;
        b2bua)
            local b2bua_reg b2bua_clients
            b2bua_reg=$(grep "^upstream_registered=" "$VOIP_STATE_DIR/b2bua_status" 2>/dev/null | cut -d= -f2)
            b2bua_clients=$(grep "^local_clients=" "$VOIP_STATE_DIR/b2bua_status" 2>/dev/null | cut -d= -f2)
            mode_info="B2BUA | upstream: ${b2bua_reg:-starting} | clients: ${b2bua_clients:-(none)}"
            ;;
        b2bua_netns)
            local b2bua_reg b2bua_clients
            b2bua_reg=$(grep "^upstream_registered=" "$VOIP_STATE_DIR/b2bua_status" 2>/dev/null | cut -d= -f2)
            b2bua_clients=$(grep "^local_clients=" "$VOIP_STATE_DIR/b2bua_status" 2>/dev/null | cut -d= -f2)
            mode_info="B2BUA NETNS | upstream: ${b2bua_reg:-starting} | clients: ${b2bua_clients:-(none)}"
            ;;
        *)       mode_info="$ROUTING_MODE" ;;
    esac

    echo ""
    echo "=========================================================="
    echo " VoIP -- Running"
    echo "=========================================================="
    echo "  Interface : $VOIP_WAN_VLAN_INTERFACE (VLAN $VOIP_WAN_VLAN on $VOIP_WAN_INTERFACE)"
    echo "  VoIP IP   : $voip_ip"
    echo "  Gateway   : $gw"
    echo "  Routing   : $mode_info"
    echo "  IMS subnet: $subnet"
    echo "  NAT       : MASQUERADE in $UBIOS_NAT_CHAIN"
    [ -n "$VOIP_VPN_INTERFACES" ] && echo "  VPN       : $VOIP_VPN_INTERFACES (VoIP forwarding enabled)"
    echo "----------------------------------------------------------"
    if [ -z "$PCSCF_HOSTNAME" ]; then
        echo "  SIP Proxy : PCSCF_HOSTNAME not set"
    elif [ "$pcscf_ip" = "(unresolved)" ]; then
        echo "  SIP Proxy : NOT RESOLVED -- check DNS via $VOIP_WAN_VLAN_INTERFACE"
    else
        if [ "$ROUTING_MODE" = "b2bua" ] || [ "$ROUTING_MODE" = "b2bua_netns" ]; then
            echo "  SIP Proxy : $pcscf_ip  (upstream, used by B2BUA)"
            _gw_ip=$(ip -o -4 addr show dev br0 2>/dev/null | awk '{print $4}' | cut -d/ -f1 | head -1)
            _gw_ip="${_gw_ip:-$(ip -o -4 addr show scope global 2>/dev/null | awk '!/lo/{print $4}' | cut -d/ -f1 | head -1)}"
            echo "  SIP Client: register to ${_gw_ip}:${VOIP_B2BUA_LISTEN_PORT} (local B2BUA)"
        else
            echo "  SIP Proxy : $pcscf_ip  <-- use this in your SIP client / ATA"
        fi
    fi
    echo "=========================================================="
    echo ""

    systemd-notify --no-block \
        "STATUS=VoIP UP | $voip_ip | P-CSCF: $pcscf_ip | mode: $ROUTING_MODE" \
        2>/dev/null || true
}

# ── Network setup / teardown ──────────────────────────────────────────────────

_network_setup() {
    ip link show "$VOIP_WAN_INTERFACE" >/dev/null 2>&1 \
        || { echo "ERROR: $VOIP_WAN_INTERFACE not found"; return 1; }

    echo "  Conntrack  : flushing stale IMS entries"
    local flush_subnet="${VOIP_IMS_SUBNET:-10.0.0.0/8}"
    conntrack -D --orig-dst "$flush_subnet" 2>/dev/null || true
    conntrack -D --reply-dst "$flush_subnet" 2>/dev/null || true
    ip route flush cache 2>/dev/null || true

    # Universal teardown: clear ALL routing rules/routes/netns from any
    # previously active mode before bringing up a fresh configuration.
    # This ensures mode switches never leave stale rules that break the new mode.
    _routing_teardown

    if [ -e "/sys/class/net/$VOIP_WAN_VLAN_INTERFACE" ]; then
        echo "$VOIP_WAN_VLAN_INTERFACE already exists, removing first"
        ip link delete dev "$VOIP_WAN_VLAN_INTERFACE" 2>/dev/null || true
    fi

    ip link add link "$VOIP_WAN_INTERFACE" name "$VOIP_WAN_VLAN_INTERFACE" \
        type vlan id "$VOIP_WAN_VLAN"
    [ -n "$VOIP_WAN_VLAN_INTERFACE_EGRESS_QOS" ] && \
        ip link set "$VOIP_WAN_VLAN_INTERFACE" type vlan \
            egress $VOIP_WAN_VLAN_INTERFACE_EGRESS_QOS
    ip link set dev "$VOIP_WAN_VLAN_INTERFACE" up

    _dhcp_start    || return 1
    _routing_setup || return 1
}

_network_teardown() {
    _routing_teardown
    _dhcp_stop
    ip link delete dev "$VOIP_WAN_VLAN_INTERFACE" 2>/dev/null || true
}

# ── Rules watchdog ────────────────────────────────────────────────────────────
# UniFiOS occasionally rewrites iptables rules (e.g. after WAN failover or
# network reconfiguration). This function re-instates any missing rules and
# is called both once after startup and every 5 seconds in the main loop.
# A lock directory prevents concurrent executions.

_rules_ensure() {
    local iface="$1" subnet="$2" mode="$3"
    local _lock="$VOIP_STATE_DIR/rules.lock"

    if ! mkdir "$_lock" 2>/dev/null; then return 0; fi
    trap 'rm -rf "$_lock"' EXIT INT TERM

    if [ "$mode" = "pbr" ] || [ "$mode" = "b2bua" ] || [ "$mode" = "b2bua_netns" ] || [ "$mode" = "forward" ]; then
        iptables -t nat -C "$UBIOS_NAT_CHAIN" \
            -o "$iface" -j MASQUERADE 2>/dev/null \
        || { iptables -t nat -A "$UBIOS_NAT_CHAIN" -o "$iface" -j MASQUERADE
             echo "  [watchdog] restored MASQUERADE on $iface"; }
    else
        iptables -t nat -C "$UBIOS_NAT_CHAIN" \
            -o "$iface" -d "$subnet" -j MASQUERADE 2>/dev/null \
        || { iptables -t nat -A "$UBIOS_NAT_CHAIN" -o "$iface" -d "$subnet" -j MASQUERADE
             echo "  [watchdog] restored MASQUERADE on $iface dst $subnet"; }
    fi

    # Watchdog only maintains what we actually set:
    #   - NAT MASQUERADE (all modes)
    #   - UBIOS_LAN_IN_USER dst $subnet (allows LAN→IMS traffic)
    #   - mangle MARK/CONNMARK (pbr and b2bua modes)
    # Raw FORWARD rules are NOT maintained — LAN and VPN traffic is allowed via
    # UniFi's own UBIOS_LAN_IN_USER and UBIOS_VPN_WAN_USER chains respectively.
    # NOTE: _wan_subif_rp_set is NOT called here — rp_filter is a kernel proc
    # setting that only resets on interface recreation, which is already handled
    # by ip-monitor events (link UP, address change, WAN recovery).

    iptables -C UBIOS_LAN_IN_USER -d "$subnet" -j ACCEPT 2>/dev/null \
    || { iptables -I UBIOS_LAN_IN_USER 1 -d "$subnet" -j ACCEPT
         echo "  [watchdog] restored UBIOS_LAN_IN_USER ACCEPT dst $subnet"; }

    if [ "$mode" = "pbr" ] || [ "$mode" = "b2bua" ]; then
        local _wd_fwmark
        _wd_fwmark=$(iptables -t mangle -L PREROUTING -n 2>/dev/null \
            | awk '/MARK xset/{match($0,/0x[0-9a-f]+\/0x[0-9a-f]+/); \
                   if(RSTART){print substr($0,RSTART,RLENGTH); exit}}')
        [ -z "$_wd_fwmark" ] && \
            _wd_fwmark=$(cat "$VOIP_STATE_DIR/fwmark" 2>/dev/null || echo "0x1e0000/0x7e0000")
        [ -n "$_wd_fwmark" ] && echo "$_wd_fwmark" > "$VOIP_STATE_DIR/fwmark"
        iptables -t mangle -C PREROUTING \
            -d "$subnet" -j MARK --set-xmark "$_wd_fwmark" 2>/dev/null \
        || { iptables -t mangle -I PREROUTING 1 \
                 -d "$subnet" -j MARK --set-xmark "$_wd_fwmark"
             iptables -t mangle -I PREROUTING 2 \
                 -d "$subnet" -j CONNMARK --save-mark --nfmask 0x7e0000
             echo "  [watchdog] restored mangle MARK/CONNMARK for $subnet"; }
        iptables -t mangle -C PREROUTING \
            -m connmark --mark "$_wd_fwmark" \
            -j CONNMARK --restore-mark --nfmask 0x7e0000 2>/dev/null \
        || { iptables -t mangle -I PREROUTING 3 \
                 -m connmark --mark "$_wd_fwmark" \
                 -j CONNMARK --restore-mark --nfmask 0x7e0000
             echo "  [watchdog] restored mangle CONNMARK restore for $subnet"; }
    elif [ "$mode" = "forward" ]; then
        local _wd_fwd_ifaces
        _wd_fwd_ifaces=$(cat "$VOIP_STATE_DIR/forward_iface" 2>/dev/null || echo "$VOIP_FORWARD_INTERFACE")
        # Routing is selected via per-interface "iif <iface> to <subnet>" rules
        # (no mangle/fwmark — see _routing_setup_forward for why).
        for _wd_iface in $_wd_fwd_ifaces; do
            ip rule show 2>/dev/null \
                | grep -qE "to $subnet iif $_wd_iface lookup" \
            || { ip rule add iif "$_wd_iface" to "$subnet" lookup "$VOIP_RT_TABLE" priority 101
                 echo "  [watchdog] restored ip rule: iif $_wd_iface to $subnet -> table $VOIP_RT_TABLE"; }
        done
    fi
        if [ "$mode" = "b2bua" ] || [ "$mode" = "b2bua_netns" ] && [ -f "$VOIP_STATE_DIR/b2bua_pid" ]; then
            local _bpid
            _bpid=$(cat "$VOIP_STATE_DIR/b2bua_pid")
            if ! kill -0 "$_bpid" 2>/dev/null; then
                echo "  [watchdog] B2BUA process died, restarting..."
                if [ "$mode" = "b2bua_netns" ]; then
                    _b2bua_netns_start
                else
                    _b2bua_start
                fi
            fi
        fi
        if [ "$mode" = "b2bua" ]; then
            # Keep port 5060 RETURN rules in place so direct IMS SIP stays
            # unroutable from LAN clients (no mark = no fwmark rule = no route).
            for _proto in udp tcp; do
                iptables -t mangle -C PREROUTING \
                    -d "$subnet" -p "$_proto" --dport 5060 -j RETURN 2>/dev/null \
                || { iptables -t mangle -I PREROUTING 1 \
                         -d "$subnet" -p "$_proto" --dport 5060 -j RETURN
                     echo "  [watchdog] restored mangle RETURN ($_proto:5060 → $subnet)"; }
            done
        fi

    # b2bua_netns: ensure the veth FORWARD rules stay in place.
    # Without these, b2bua responses exit the netns via b2bua_v0 but are
    # silently dropped by the FORWARD chain before reaching LAN clients.
    if [ "$mode" = "b2bua_netns" ]; then
        iptables -C FORWARD -i b2bua_v0 -j ACCEPT 2>/dev/null \
        || { iptables -I FORWARD 1 -i b2bua_v0 -j ACCEPT
             echo "  [watchdog] restored FORWARD -i b2bua_v0 ACCEPT"; }
        iptables -C FORWARD -o b2bua_v0 -j ACCEPT 2>/dev/null \
        || { iptables -I FORWARD 1 -o b2bua_v0 -j ACCEPT
             echo "  [watchdog] restored FORWARD -o b2bua_v0 ACCEPT"; }
    fi

    rm -rf "$_lock"
    trap - EXIT INT TERM
}

# ── Entry point ───────────────────────────────────────────────────────────────

[ $# -eq 0 ] && echo "Usage: $0 {start|stop|status}" && exit 1

case $1 in
    start)
        mkdir -p "$VOIP_STATE_DIR"
        _network_setup || { echo "FATAL: network setup failed"; exit 1; }
        _resolve_pcscf
        if [ "$ROUTING_MODE" = "b2bua_netns" ]; then
            _b2bua_netns_start || echo "WARNING: B2BUA failed to start — check config"
        elif [ "$ROUTING_MODE" = "b2bua" ]; then
            _b2bua_start || echo "WARNING: B2BUA failed to start — check config"
        fi
        _show_status
        echo "VoIP service started (mode: $ROUTING_MODE)"

        # Give UniFiOS a few seconds to finish its own post-boot network work
        # before we verify rules, to avoid a race with its iptables restore.
        echo "Waiting for UniFiOS to settle (3s)..."
        sleep 3
        _rules_ensure \
            "$VOIP_WAN_VLAN_INTERFACE" \
            "$(cat $VOIP_STATE_DIR/subnet 2>/dev/null || echo ${VOIP_IMS_SUBNET:-10.0.0.0/8})" \
            "$ROUTING_MODE"
        echo "Rules confirmed (post-settle)."

        echo "down" > "$VOIP_STATE_DIR/link_state"
        echo "up"   > "$VOIP_STATE_DIR/link_state"
        (
            # Monitor link and address events. On WAN link recovery, tear down
            # and rebuild the VoIP stack so a fresh DHCP lease is obtained.
            ip monitor link address 2>/dev/null | while IFS= read -r _evt; do
                if echo "$_evt" | grep -q ": ${VOIP_WAN_INTERFACE}:"; then
                    if echo "$_evt" | grep -qE "state (DOWN|UNKNOWN)|Deleted"; then
                        echo "[ip-monitor] $VOIP_WAN_INTERFACE DOWN"
                        echo "down" > "$VOIP_STATE_DIR/link_state"
                    elif echo "$_evt" | grep -q "state UP"; then
                        if [ "$(cat $VOIP_STATE_DIR/link_state 2>/dev/null)" = "down" ]; then
                            echo "[ip-monitor] $VOIP_WAN_INTERFACE UP — waiting 4s for link to settle"
                            echo "up" > "$VOIP_STATE_DIR/link_state"
                            sleep 4
                            conntrack -D --orig-dst "${VOIP_IMS_SUBNET:-10.0.0.0/8}" 2>/dev/null || true
                            conntrack -D --reply-dst "${VOIP_IMS_SUBNET:-10.0.0.0/8}" 2>/dev/null || true
                            _network_setup || { echo "[ip-monitor] ERROR: setup failed"; continue; }
                            if [ "$ROUTING_MODE" = "b2bua_netns" ]; then
                                _resolve_pcscf
                                _b2bua_netns_stop; _b2bua_netns_start
                            elif [ "$ROUTING_MODE" = "b2bua" ]; then
                                _resolve_pcscf
                                _b2bua_stop; _b2bua_start
                            fi
                            sleep 3
                            _rules_ensure \
                                "$VOIP_WAN_VLAN_INTERFACE" \
                                "$(cat $VOIP_STATE_DIR/subnet 2>/dev/null || echo ${VOIP_IMS_SUBNET:-10.0.0.0/8})" \
                                "$ROUTING_MODE"
                            _resolve_pcscf
                            _show_status
                            echo "[ip-monitor] $VOIP_WAN_INTERFACE link recovery complete"
                        fi
                    fi
                fi

                # A WAN subinterface coming UP after a toggle needs rp_filter cleared
                if echo "$_evt" | grep -q "@${VOIP_WAN_INTERFACE}" && \
                   echo "$_evt" | grep -q "state UP" && \
                   ! echo "$_evt" | grep -qw "$VOIP_WAN_VLAN_INTERFACE"; then
                    _sub=$(echo "$_evt" | awk -F'[ :@]' '{for(i=1;i<=NF;i++) if($i~/^[a-z]/ && $i!~/state/) {print $i; exit}}')
                    if [ -n "$_sub" ] && [ "$_sub" != "$VOIP_WAN_VLAN_INTERFACE" ]; then
                        echo 0 > "/proc/sys/net/ipv4/conf/${_sub}/rp_filter" 2>/dev/null || true
                        echo "[ip-monitor] rp_filter set to 0 on $_sub (WAN subif UP after toggle)"
                    fi
                fi

                # voip interface address event — re-check routing table and rules
                if echo "$_evt" | grep -qw "$VOIP_WAN_VLAN_INTERFACE" && \
                   ! echo "$_evt" | grep -q "Deleted"; then
                    sleep 2
                    if ! ip route show table "$VOIP_RT_TABLE" 2>/dev/null | grep -q .; then
                        echo "[ip-monitor] table $VOIP_RT_TABLE empty — restoring routing"
                        _routing_setup "false" \
                            && echo "[ip-monitor] routing restored (table $VOIP_RT_TABLE OK)" \
                            || echo "[ip-monitor] ERROR: routing restore failed"
                        if [ "$ROUTING_MODE" = "b2bua_netns" ]; then
                            _b2bua_netns_stop; _b2bua_netns_start
                        elif [ "$ROUTING_MODE" = "b2bua" ]; then
                            _b2bua_stop; _b2bua_start
                        fi
                        sleep 3
                    fi
                    _rules_ensure \
                        "$VOIP_WAN_VLAN_INTERFACE" \
                        "$(cat $VOIP_STATE_DIR/subnet 2>/dev/null || echo ${VOIP_IMS_SUBNET:-10.0.0.0/8})" \
                        "$ROUTING_MODE"
                fi
            done
        ) &
        echo $! > "$VOIP_STATE_DIR/monitor_pid"
        echo "ip monitor started (PID $(cat $VOIP_STATE_DIR/monitor_pid))"

        # Main watchdog loop — re-ensures rules every 5 seconds
        while true; do
            sleep 5
            _rules_ensure \
                "$VOIP_WAN_VLAN_INTERFACE" \
                "$(cat "$VOIP_STATE_DIR/subnet" 2>/dev/null \
                    || echo "${VOIP_IMS_SUBNET:-10.0.0.0/8}")" \
                "$ROUTING_MODE"
        done
        ;;
    stop)
        # Kill the ip-monitor subshell AND its child (ip monitor process).
        # A simple kill only kills the subshell; ip monitor is a grandchild
        # and survives, showing up in systemd as a lingering unit process.
        if [ -f "$VOIP_STATE_DIR/monitor_pid" ]; then
            _mpid=$(cat "$VOIP_STATE_DIR/monitor_pid")
            # Kill the entire process group to catch ip monitor child
            kill -- -"$_mpid" 2>/dev/null || kill "$_mpid" 2>/dev/null || true
            rm -f "$VOIP_STATE_DIR/monitor_pid"
        fi
        _network_teardown
        # Preserve the resolved subnet — it is read by _detect_voip_config
        # on the next start to skip DNS re-resolution (cache).  Removing it
        # here forces a fresh DNS lookup on every restart, which can fail.
        rm -f "$VOIP_STATE_DIR/voip_ip"     "$VOIP_STATE_DIR/gw" \
              "$VOIP_STATE_DIR/pcscf_ip"    "$VOIP_STATE_DIR/forward_iface" \
              "$VOIP_STATE_DIR/link_state"  "$VOIP_STATE_DIR/b2bua_pid" \
              "$VOIP_STATE_DIR/b2bua_status"
        echo "VoIP service stopped"
        ;;
    status)
        _show_status
        ;;
    *)
        echo "Usage: $0 {start|stop|status}"
        exit 1
        ;;
esac