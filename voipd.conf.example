# /data/voip/voipd.conf
# VoIP configuration for UniFiOS
#
# This file is managed by the voip-ui web interface (https://<gateway>/voip)
# You can also edit it manually. Changes take effect after restarting the service.
#
# Generated by: voip install
# ============================================================

# Physical WAN port the VoIP VLAN is attached to
# UCG-Fiber: eth4 (RJ45 WAN) or eth6 (SFP+ WAN)
# UDM-Pro:   eth8 or eth9
VOIP_WAN_INTERFACE="eth4"

# VLAN ID your ISP uses for VoIP traffic (verify with your ISP or ONT)
VOIP_WAN_VLAN="11"

# Name of the VLAN subinterface that will be created (safe to leave as "voip")
VOIP_WAN_VLAN_INTERFACE="voip"

# DSCP/QoS egress CoS mapping — maps all internal CoS values to CoS 5 (Voice)
VOIP_WAN_VLAN_INTERFACE_EGRESS_QOS="0:5 1:5 2:5 3:5 4:5 5:5 6:5 7:5"

# ISP's P-CSCF hostname for DNS resolution at startup
# Leave as example value if your ISP does not use IMS/P-CSCF
PCSCF_HOSTNAME="p-cscf.example.com"

# Routing mode: "b2bua" (default, recommended), "pbr" or "forward"
ROUTING_MODE="b2bua"

# --- B2BUA mode (only used when ROUTING_MODE="b2bua") -------------------------
# ISP SIP credentials the B2BUA registers to the IMS network upstream.
# LAN clients register to the gateway instead of the ISP directly.
# RTP still flows peer-to-peer — no media is relayed by the gateway.
VOIP_B2BUA_USER=""
VOIP_B2BUA_PASS=""
VOIP_B2BUA_DOMAIN=""
# Local SIP port (UDP + TCP) — default 5060
VOIP_B2BUA_LISTEN_PORT="5060"
# Optional local account for clients (leave empty to allow any client without auth)
VOIP_B2BUA_LOCAL_USER=""
VOIP_B2BUA_LOCAL_PASS=""
# REGISTER refresh interval in seconds
VOIP_B2BUA_REG_EXPIRES="600"

# --- Voip routing table (used by pbr and b2bua modes) ------------------------
# Auto-detected at install to avoid conflicts with UniFiOS WAN tables
# (201, 202...). Do NOT change unless you have a table conflict.
VOIP_RT_TABLE="203"
VOIP_RT_TABLE_NAME="voip"

# --- Forward mode (only used when ROUTING_MODE="forward") --------------------
VOIP_FORWARD_INTERFACE=""
VOIP_FORWARD_GATEWAY=""

# --- IMS subnet override -----------------------------------------------------
# Leave empty for auto-detection from DHCP-assigned IP (recommended)
# Override example: VOIP_IMS_SUBNET="10.0.0.0/8"
VOIP_IMS_SUBNET=""

# --- VPN support (optional) --------------------------------------------------
# Space-separated WireGuard interface names to allow VoIP traffic from.
# Enables SIP/RTP over Teleport or the built-in WireGuard VPN server.
# Leave empty to disable — VPN clients will not have VoIP access by default.
# Find your WireGuard interface with: ip link show type wireguard
# Example: VOIP_VPN_INTERFACES="wg0"
VOIP_VPN_INTERFACES=""

# Set to "true" for verbose debug output in journalctl
VOIP_DEBUG="false"
