# Node / npm
ui/panel/node_modules/
ui/panel/.npm/
ui/panel/package-lock.json

# Vite build output — distributed as GitHub Release asset (ui-dist.tar.gz)
ui/panel/dist/

# Vite cache
ui/panel/.vite/

# TypeScript cache
ui/panel/*.tsbuildinfo
ui/panel/tsconfig.app.json
ui/panel/tsconfig.node.json

# Release archives (built locally, uploaded to GitHub Releases manually)
ui/ui-dist.tar.gz
*.tar.gz

# panel has its own .gitignore (generated by Vite/lovable) — ignore it,
# the root .gitignore covers everything
ui/panel/.gitignore

# Editor & OS
.DS_Store
Thumbs.db
*.swp
*.swo
.vscode/
.idea/

# Local env overrides
.env.local
.env.*.local

# nginx backup files created by install-ui
*.voip-bak
*.voip-bak-rm

# Internal token (generated at install time, never committed)
ui/.internal-token
